# ===========================================================
# AI Outreach Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ===========================================================

# PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/outreach_db

# SMTP (for sending emails — use Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here

# IMAP (for reading replies — same Gmail account works)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
IMAP_PASS=your_app_password_here

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_numeric_chat_id

# Ollama (local LLM server)
OLLAMA_BASE_URL=http://localhost:11434

# GitHub (optional — increases rate limit for README fetching)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_store
